---
import { isPlaceholder, siteConfig } from '@config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__top">
      <div class="site-footer__brand">
        <a class="brand" href="/" aria-label="Brzytwa Barber — strona główna">
          <span class="brand__name">Brzytwa <span>Barber</span></span>
        </a>
        <p>Precyzyjne strzyżenie i świadoma pielęgnacja w centrum Katowic.</p>
      </div>

      <div>
        <h2 class="site-footer__heading">Nawigacja</h2>
        <ul class="site-footer__links">
          {
            siteConfig.navigation.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))
          }
          <li><a href="/rezerwacja">Rezerwacja</a></li>
        </ul>
      </div>

      <div>
        <h2 class="site-footer__heading">Kontakt</h2>
        <address class="site-footer__contact">
          <span>{siteConfig.contact.address}</span>
          {
            isPlaceholder(siteConfig.contact.phone) ? (
              <span>{siteConfig.contact.phone}</span>
            ) : (
              <a href={`tel:${siteConfig.contact.phone}`}>{siteConfig.contact.phone}</a>
            )
          }
          {
            isPlaceholder(siteConfig.contact.email) ? (
              <span>{siteConfig.contact.email}</span>
            ) : (
              <a href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a>
            )
          }
        </address>
      </div>

      <div>
        <h2 class="site-footer__heading">Godziny</h2>
        <dl class="hours hours--compact">
          {
            siteConfig.businessHours.map((item) => (
              <div>
                <dt>{item.days}</dt>
                <dd class:list={{ 'is-closed': item.closed }}>{item.hours}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>

    <div class="site-footer__bottom">
      <p>© {year} {siteConfig.name}. Wszelkie prawa zastrzeżone.</p>
      <nav aria-label="Informacje prawne">
        {siteConfig.legalNavigation.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </div>
  </div>
</footer>
