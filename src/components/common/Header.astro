---
import { siteConfig } from '@config/site';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const isCurrent = (href: string): boolean => {
  const normalizedHref = href.replace(/\/$/, '') || '/';
  return normalizedHref === currentPath;
};

const splitIndex = Math.ceil(siteConfig.navigation.length / 2);
const leftNavigation = siteConfig.navigation.slice(0, splitIndex);
const rightNavigation = siteConfig.navigation.slice(splitIndex);
---

<header class="site-header" data-site-header>
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label="Brzytwa Barber — strona główna">
      <span class="brand__name">Brzytwa <span>Barber</span></span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="main-navigation"
      aria-label="Otwórz menu"
      data-nav-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="site-nav" id="main-navigation" aria-label="Główna nawigacja" data-navigation>
      <ul class="site-nav__list site-nav__list--left">
        {
          leftNavigation.map((item) => (
            <li>
              <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <ul class="site-nav__list site-nav__list--right">
        {
          rightNavigation.map((item) => (
            <li>
              <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="site-nav__booking">
          <a
            class="button button--small"
            href="/rezerwacja"
            aria-current={isCurrent('/rezerwacja') ? 'page' : undefined}
          >
            Rezerwacja
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
