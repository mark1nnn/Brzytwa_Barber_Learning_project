---
import { siteConfig } from "@config/site";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const isCurrent = (href: string): boolean => {
  const normalizedHref = href.replace(/\/$/, "") || "/";
  return normalizedHref === currentPath;
};
---

<header class="site-header" data-site-header>
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label="Brzytwa Barber — strona główna">
      <svg class="brand__mark" viewBox="0 0 44 44" aria-hidden="true">
        <path d="M8 8h16.5C31.4 8 36 11.7 36 17.2c0 3.5-1.9 6.2-5.1 7.7 4 1.2 6.1 4.2 6.1 8 0 6.7-5.5 10.1-13.1 10.1H8V8Zm9 7v7h7c2.4 0 4-1.2 4-3.5S26.3 15 23.8 15H17Zm0 13.5V36h7.8c2.9 0 4.7-1.3 4.7-3.8s-1.8-3.7-4.8-3.7H17Z"></path>
      </svg>
      <span class="brand__name">Brzytwa <span>Barber</span></span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="main-navigation"
      aria-label="Otwórz menu"
      data-nav-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="site-nav" id="main-navigation" aria-label="Główna nawigacja" data-navigation>
      <ul class="site-nav__list">
        {
          siteConfig.navigation.map((item) => (
            <li>
              <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a class="button button--small" href="/rezerwacja">Rezerwacja</a>
    </nav>
  </div>
</header>
