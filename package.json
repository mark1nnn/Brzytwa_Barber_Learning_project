{
  "name": "brzytwa-barber",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "pages:dev": "npm run build && wrangler pages dev dist",
    "d1:migrations:list:local": "wrangler d1 migrations list DB --local",
    "d1:migrations:apply:local": "wrangler d1 migrations apply DB --local",
    "d1:migrations:list:remote": "wrangler d1 migrations list DB --remote",
    "d1:migrations:apply:remote": "wrangler d1 migrations apply DB --remote",
    "d1:query:local": "wrangler d1 execute DB --local"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "astro": "7.0.5",
    "gsap": "3.13.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "typescript": "6.0.3",
    "vite": "8.1.2",
    "wrangler": "4.106.0"
  },
  "overrides": {
    "yaml-language-server": {
      "yaml": "2.8.3"
    }
  }
}
