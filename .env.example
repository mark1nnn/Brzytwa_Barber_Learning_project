# Replace this reserved non-production URL before publishing the website.
PUBLIC_SITE_URL=https://example.invalid

# Public widget key. Replace with a real Turnstile site key before enabling booking UI.
PUBLIC_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key

# Server-only placeholders. Use .dev.vars locally and Cloudflare secrets in deployment.
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL="Brzytwa Barber <booking@example.invalid>"
ADMIN_NOTIFICATION_EMAIL=admin@example.invalid
